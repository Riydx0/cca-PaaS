# ============================================================
# cca-PaaS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Database (internal — used between Docker containers)
# docker-compose auto-builds DATABASE_URL from DB_PASSWORD:
#   postgresql://cca:<DB_PASSWORD>@db:5432/cca_paas
# For local dev (outside Docker), set DATABASE_URL directly:
# DATABASE_URL=postgresql://user:password@localhost:5432/cca_paas
# ------------------------------------------------------------
DB_PASSWORD=change_this_to_a_strong_random_password

# ------------------------------------------------------------
# Session
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
SESSION_SECRET=replace_with_a_random_32_char_string

# ------------------------------------------------------------
# HTTPS Cookie Security
# Set to "true" ONLY when serving over HTTPS (SSL/TLS).
# When false (default), cookies work on HTTP as well.
# The setup script sets this automatically based on your domain config.
# ------------------------------------------------------------
# COOKIE_SECURE=true

# ------------------------------------------------------------
# App URL (optional — set by setup wizard)
# The public URL of this instance (e.g. https://app.yourdomain.com)
# ------------------------------------------------------------
# APP_URL=https://app.yourdomain.com

# ------------------------------------------------------------
# Server (optional)
# Port to expose on the host machine (default: 80)
# ------------------------------------------------------------
# LISTEN_PORT=80

# ------------------------------------------------------------
# Cloudron Integration (optional)
# Allows admins to manage Cloudron-hosted apps from this panel.
#
# CLOUDRON_ENABLED   — set to "true" to activate the integration.
# CLOUDRON_BASE_URL  — base URL of your Cloudron instance
#                      (e.g. https://my.cloudron.io — no trailing slash).
# CLOUDRON_API_TOKEN — API token from the Cloudron dashboard.
#                      Generate one at: Cloudron Settings → API Access.
#
# After setting these variables, verify the connection with:
#   GET /api/cloudron/test   (requires admin login)
# ------------------------------------------------------------
# CLOUDRON_ENABLED=true
# CLOUDRON_BASE_URL=https://my.cloudron.io
# CLOUDRON_API_TOKEN=your_cloudron_api_token_here

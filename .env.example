# ============================================================
# cca-PaaS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Database (internal — used between Docker containers)
# ------------------------------------------------------------
DB_PASSWORD=change_this_to_a_strong_random_password

# ------------------------------------------------------------
# Clerk Authentication
# Get these from: https://dashboard.clerk.com → API Keys
# ------------------------------------------------------------
CLERK_SECRET_KEY=sk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Optional: Custom domain Clerk proxy (advanced)
# VITE_CLERK_PROXY_URL=https://yourdomain.com/clerk

# ------------------------------------------------------------
# Session
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
SESSION_SECRET=replace_with_a_random_32_char_string

# ------------------------------------------------------------
# Server (optional)
# Port to expose on the host machine (default: 80)
# ------------------------------------------------------------
# LISTEN_PORT=80
